# ── Story Engine Environment ──────────────────────────────────────────────────

# Required: OpenAI for DALL-E image generation
OPENAI_API_KEY=sk-...

# Required: Anthropic Claude for story/storyboard generation
ANTHROPIC_API_KEY=sk-ant-...

# Required: ElevenLabs for voiceover narration
ELEVENLABS_API_KEY=...

# Optional: Google Veo for AI video generation (falls back to FFmpeg motion if not set)
GOOGLE_VEO_API_KEY=...
GOOGLE_CLOUD_PROJECT=...

# Server ports
PORT=3420

# URL to the existing media-pipeline (for Remotion rendering)
MEDIA_PIPELINE_URL=http://localhost:9004
